{
  "description": "Allumer uniquement le bouton 9",
  "targetState": [0,0,0,0,0,0,0,0,1],
  "difficulty": "intermédiaire",
  "validationQuestions": [
    {
      "description": "Si l'état initial est celui-ci et qu'on clique sur le bouton 3, quel sera l'état suivant ?",
      "initialState": [0,0,0,0,0,0,0,0,0],
      "clickButton": 3,
      "expectedState": [0,0,0,0,0,0,0,0,1]
    },
    {
      "description": "Si l'état initial est celui-ci et qu'on clique sur le bouton 4, quel sera l'état suivant ?",
      "initialState": [1,0,0,0,0,0,0,0,0],
      "clickButton": 4,
      "expectedState": [0,0,0,0,0,0,1,0,0]
    },
    {
      "description": "Si l'état initial est celui-ci et qu'on clique sur le bouton 6, quel sera l'état suivant ?",
      "initialState": [0,0,0,0,0,0,0,1,0],
      "clickButton": 6,
      "expectedState": [0,1,0,0,0,0,0,0,0]
    }
  ],
  "rule": [
    "let carre = (index + 1) * (index + 1);",
    "buttons.fill(false);",
    "if (carre <= 9) {",
    "  buttons[carre - 1] = true;",
    "} else {",
    "  buttons[(index * 2) % 9] = true;",
    "}"
  ]
}