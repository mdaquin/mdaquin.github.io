{
  "description": "Allumer uniquement les boutons 1, 3 et 7",
  "targetState": [1,0,1,0,0,0,1,0,0],
  "difficulty": "difficile",
  "validationQuestions": [
    {
      "description": "L'historique est vide. On clique sur le bouton 5. Quel est l'état suivant ?",
      "historique": [],
      "initialState": [0,0,0,0,0,0,0,0,0],
      "clickButton": 5,
      "expectedState": [0,1,0,1,1,1,0,1,0]
    },
    {
      "description": "L'historique est vide. On clique sur le bouton 2. Quel est l'état suivant ?",
      "historique": [],
      "initialState": [1,1,0,1,1,0,0,0,0],
      "clickButton": 2,
      "expectedState": [0,0,1,1,0,0,0,0,0]
    },
    {
      "description": "L'historique est vide. On clique sur le bouton 4. Quel est l'état suivant ?",
      "historique": [],
      "initialState": [0,0,1,1,1,0,0,0,0],
      "clickButton": 4,
      "expectedState": [1,0,1,0,0,0,1,0,0]
    },
    {
      "description": "On a déjà cliqué sur le bouton 1. On clique maintenant sur le bouton 2. Quel est l'état suivant ?",
      "historique": [{"button": 1}],
      "initialState": [1,1,0,1,0,0,0,0,0],
      "clickButton": 2,
      "expectedState": [0,0,1,1,1,0,0,0,0]
