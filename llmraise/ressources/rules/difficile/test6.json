  "rule": [
    "let row = Math.floor(index / 3), col = index % 3;",
    "buttons[index] = !buttons[index];",
    "if (row > 0) buttons[index - 3] = !buttons[index - 3];",
    "if (row < 2) buttons[index + 3] = !buttons[index + 3];",
    "if (col > 0) buttons[index - 1] = !buttons[index - 1];",
    "if (col < 2) buttons[index + 1] = !buttons[index + 1];",
    "//sol : 1,2,4"
  ]
