    ],
    "rule": [
    "let pairs = 0, impairs = 0;",
    "for (let h of historiques) {",
    "  if (h.button % 2 === 0) pairs++;",
    "  else impairs++;",
    "}",
    "let bouton = index + 1;",
    "if (bouton % 2 === 0) pairs++;",
    "else impairs++;",
    "buttons.fill(false);",
    "if (pairs === impairs && pairs > 0) {",
    "  buttons[index] = true;",
    "}",
