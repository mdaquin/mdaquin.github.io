{
  "description": "Allumer uniquement le bouton central (5)",
  "targetState": [1,0,0,0,1,0,0,0,0],
  "difficulty": "moyen",
  "validationQuestions": [
    {
      "description": "Clic sur le bouton 1 depuis l'état vide — quels boutons s'allument ?",
      "initialState": [0,0,0,0,0,0,0,0,0],
      "clickButton": 1,
      "expectedState": [1,1,0,1,0,0,0,0,0]
    },
    {
      "description": "Clic sur le bouton 5 depuis l'état vide — quels boutons s'allument ?",
      "initialState": [0,0,0,0,0,0,0,0,0],
      "clickButton": 5,
      "expectedState": [0,0,0,0,1,1,0,1,0]
    },
    {
      "description": "Clic sur le bouton 9 depuis cet état — que se passe-t-il ?",
      "initialState": [0,0,0,0,0,0,1,0,0],
      "clickButton": 9,
      "expectedState": [0,0,1,0,0,0,0,0,1]
    }
  ],
  "rule": [
    "const row = Math.floor(index / 3);",
    "const col = index % 3;",
    "buttons[index] = !buttons[index];",
    "const hNeighbor = row * 3 + (col + 1) % 3;",
    "buttons[hNeighbor] = !buttons[hNeighbor];",
    "const vNeighbor = ((row + 1) % 3) * 3 + col;",
    "buttons[vNeighbor] = !buttons[vNeighbor];",
    "//5 → 1 → 6 → 8"
  ]
}
